generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model SleepRecord {
  id            String   @id @default(uuid())
  date          DateTime
  bedTime       DateTime
  wakeTime      DateTime
  sleepDuration Float
  deepSleep     Float?
  lightSleep    Float?
  remSleep      Float?
  awakeCount    Int?
  sleepScore    Int?
  heartRate     Int?
  createdAt     DateTime @default(now())

  @@index([date])
}

model AnalysisReport {
  id           String   @id @default(uuid())
  title        String
  summary      String
  suggestions  String
  sleepQuality String
  dataRange    String
  createdAt    DateTime @default(now())
}
